# ── GitHub auth: the shared "service" identity ───────────────────────────────────
# Used for reads, sync, webhook, and — unless the per-user GitHub OAuth section below
# is enabled — every write. Provide EITHER a token (Option A) OR GitHub App creds (Option B).
#
# Option A — Personal access token. Writes appear as that account (a person or a bot user).
GITHUB_TOKEN=
#
# Option B — GitHub App (preferred for a bot identity): writes appear as the app's bot
# (app-name[bot]) and the installation token auto-renews (~1h TTL). Set all three below;
# they take precedence over GITHUB_TOKEN — leave GITHUB_TOKEN blank to avoid confusion.
# To keep every write on the bot, also leave the GitHub OAuth section below blank (setting
# it routes user writes through each caller's own account instead).
#   Create + install the App on the org that owns the repo, with permissions:
#     Repository → Issues, Pull requests, Contents: Read & write;  Metadata: Read
#     Organization → Projects: Read & write   (needed for the Kanban tab)
#   App ID + Installation ID come from the App's settings / install page.
#   GITHUB_APP_PRIVATE_KEY accepts raw PEM, PEM with literal \n, or base64 of the .pem:
#     base64 -i your-app.private-key.pem | tr -d '\n'
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_OWNER=
GITHUB_REPO=
# Optional: pin Kanban tab to a single project number (e.g. 42). Leave blank to mirror all repo projects.
GITHUB_PROJECT_NUMBER=
GITHUB_WEBHOOK_SECRET=
PORT=3000
DB_PATH=./data/roadmap.db

# AI features (issue summaries + progress analysis).
# Points at any OpenAI-compatible HTTP endpoint — OpenCode, Codex, Ollama, vLLM, etc.
# When AI_BASE_URL or AI_MODEL is unset, AI routes return 503 and the UI hides AI surfaces.
AI_BASE_URL=http://localhost:4096/v1
# Many local servers ignore this but still require a non-empty value.
AI_API_KEY=sk-local
# Fallback default model when no per-task override is set in the app UI.
# Per-task overrides (summary / progress / insight extract) can be configured
# in the UI via the "AI" button in the header. AI stays enabled as long as
# AI_BASE_URL is set AND either AI_MODEL or at least one per-task override is set.
AI_MODEL=

# --- Google OAuth login (optional) -------------------------------------------------
# Leave GOOGLE_CLIENT_ID/SECRET blank to run as the original single-user localhost tool
# (no login, every request is a local admin). Set BOTH to require "Sign in with Google"
# for the whole app. Create credentials at https://console.cloud.google.com/apis/credentials
# (OAuth client → Web application). Authorized redirect URI must be: <app-origin>/api/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: override the redirect URI sent to Google. Defaults to <request-origin>/api/auth/callback.
# Set this when behind a proxy/custom domain so it matches what's registered in Google.
GOOGLE_OAUTH_REDIRECT=
# Optional: restrict sign-in to one email domain (e.g. katalon.com). Blank = any Google account.
ALLOWED_EMAIL_DOMAIN=
# Optional: comma-separated admin emails — the IMMUTABLE bootstrap-admin list. These users are
# always admins and cannot be demoted in-app (no lock-out). Admins manage user roles
# (viewer/editor/admin), AI model settings, and export/import. When set, newly signed-in users
# default to read-only viewers until promoted. Blank = every signed-in user is an admin
# (fine for a small trusted team).
ADMIN_EMAILS=
# Optional: secret used to sign session cookies. Defaults to GOOGLE_CLIENT_SECRET if unset.
# Set a long random value in production; changing it invalidates all existing sessions.
SESSION_SECRET=

# --- GitHub OAuth write identity (optional, requires Google login) -----------------
# Leave both blank and every GitHub write uses the shared service identity above
# (GITHUB_TOKEN or the GitHub App) — single-user mode, writes act as that identity.
# Set BOTH (setting exactly one refuses to boot) and user-initiated GitHub writes (issues,
# comments, Kanban moves, insight PRs) act as the caller's own GitHub account: each user
# connects once via the "Connect GitHub" prompt; unlinked users get 409 on writes until then.
# Requires Google login to be enabled (refuses to boot otherwise — identities must be per-human).
# Register an OAuth App (org-owned preferred) at https://github.com/settings/applications/new
# with callback URL <app-origin>/api/github/callback and request scope `repo`.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Optional: override the redirect URI sent to GitHub. Defaults to <request-origin>/api/github/callback.
GITHUB_OAUTH_REDIRECT=
# Required when GitHub OAuth is enabled: 32-byte key (hex, 64 chars, or base64) used to
# AES-256-GCM-encrypt stored user tokens at rest. Generate: openssl rand -hex 32
# Refuses to boot if OAuth is enabled and this is unset/invalid. Unused when OAuth is off.
TOKEN_ENC_KEY=

# Insights are mirrored from the canonical GitHub repo via the API (same model as
# issues) — no local checkout. They reuse the GitHub auth + OWNER/REPO above by default.
# Optional: point insights at a different repo than the issues repo (format: owner/repo).
INSIGHTS_GITHUB_REPO=
