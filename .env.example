GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
# Optional: pin Kanban tab to a single project number (e.g. 42). Leave blank to mirror all repo projects.
GITHUB_PROJECT_NUMBER=
GITHUB_WEBHOOK_SECRET=
PORT=3000
DB_PATH=./data/roadmap.db

# AI features (issue summaries + progress analysis).
# Points at any OpenAI-compatible HTTP endpoint — OpenCode, Codex, Ollama, vLLM, etc.
# When AI_BASE_URL or AI_MODEL is unset, AI routes return 503 and the UI hides AI surfaces.
AI_BASE_URL=http://localhost:4096/v1
# Many local servers ignore this but still require a non-empty value.
AI_API_KEY=sk-local
# Fallback default model when no per-task override is set in the app UI.
# Per-task overrides (summary / progress / insight extract) can be configured
# in the UI via the "AI" button in the header. AI stays enabled as long as
# AI_BASE_URL is set AND either AI_MODEL or at least one per-task override is set.
AI_MODEL=

# --- Google OAuth login (optional) -------------------------------------------------
# Leave GOOGLE_CLIENT_ID/SECRET blank to run as the original single-user localhost tool
# (no login, every request is a local admin). Set BOTH to require "Sign in with Google"
# for the whole app. Create credentials at https://console.cloud.google.com/apis/credentials
# (OAuth client → Web application). Authorized redirect URI must be: <app-origin>/api/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: override the redirect URI sent to Google. Defaults to <request-origin>/api/auth/callback.
# Set this when behind a proxy/custom domain so it matches what's registered in Google.
GOOGLE_OAUTH_REDIRECT=
# Optional: restrict sign-in to one email domain (e.g. katalon.com). Blank = any Google account.
ALLOWED_EMAIL_DOMAIN=
# Optional: comma-separated admin emails — the IMMUTABLE bootstrap-admin list. These users are
# always admins and cannot be demoted in-app (no lock-out). Admins manage user roles
# (viewer/editor/admin), AI model settings, and export/import. When set, newly signed-in users
# default to read-only viewers until promoted. Blank = every signed-in user is an admin
# (fine for a small trusted team).
ADMIN_EMAILS=
# Optional: secret used to sign session cookies. Defaults to GOOGLE_CLIENT_SECRET if unset.
# Set a long random value in production; changing it invalidates all existing sessions.
SESSION_SECRET=

# Insights are mirrored from the canonical GitHub repo via the API (same model as
# issues) — no local checkout. They use GITHUB_TOKEN/OWNER/REPO by default.
# Optional: point insights at a different repo than the issues repo (format: owner/repo).
INSIGHTS_GITHUB_REPO=
